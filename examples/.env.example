# Ejemplo de variables de entorno (copiar a .env)
# Canal: solo Web Service SAT v1.5 (FIEL). No CIEC / portal.

# Empresa por defecto (multi-empresa: fiel/{RFC}/)
SAT_DEFAULT_RFC=
SAT_CER_PATH=fiel/MI_RFC/certificado.cer
SAT_KEY_PATH=fiel/MI_RFC/llave.key
SAT_KEY_PASSWORD=

SAT_DOWNLOAD_DIR=downloads
SAT_STATE_DIR=state
SAT_LISTAS_DIR=listas

# Export CONTPAQi Contabilidad — Almacén Digital (ADD)
SAT_EXPORT_DIR=export/contpaqi_add
SAT_EMPRESA_RFC=
SAT_CONTPAQI_ZIP=true

# Reportes
SAT_REPORTES_DIR=export/reportes

# Sync / scheduler
SAT_SYNC_TIPOS=recibidos
SAT_SYNC_INCLUIR_METADATA=true
SAT_SYNC_INCLUIR_RETENCIONES=false

# Auditoría
SAT_AUDITORIA_69B_PATH=listas/69b_latest.csv

# PDF (opcional)
SAT_PDF_DIR=export/pdf
SAT_PDF_ENABLED=false
